# GlitchHunter v3.0 Docker Image - Web-UI Only
# Optimiert für schnelles Deployment

FROM python:3.11-slim

WORKDIR /app

# System-Dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    sshfs \
    fuse \
    openssh-client \
    && rm -rf /var/lib/apt/lists/*

# SSH known_hosts vorbereiten
RUN mkdir -p /root/.ssh && chmod 700 /root/.ssh

# Python-Dependencies (nur Web-UI relevant)
RUN pip install --no-cache-dir --upgrade pip && \
    pip install --no-cache-dir \
    fastapi>=0.115.0 \
    uvicorn[standard]>=0.30.0 \
    pydantic>=2.0.0 \
    pydantic-settings>=2.0.0 \
    python-multipart>=0.0.9 \
    httpx>=0.27.0 \
    cryptography>=42.0.0 \
    networkx>=3.0.0 \
    numpy>=1.24.0 \
    langgraph>=0.2.0 \
    langchain>=0.3.0 \
    langchain-core>=0.3.0 \
    langchain-openai>=0.2.0 \
    python-json-logger>=2.0.0 \
    pyyaml>=6.0.0 \
    pynvml>=11.5.0 \
    tenacity>=8.2.0 \
    rich>=13.0.0 \
    click>=8.0.0

# Web-UI kopieren
COPY ui/web/ ui/web/

# src/ für agent-Imports kopieren
COPY src/ src/

COPY config.yaml ./

# Verzeichnisse erstellen
RUN mkdir -p /app/logs /app/data /app/cache /app/reports

# Umgebungsvariablen
ENV PYTHONUNBUFFERED=1
ENV PYTHONDONTWRITEBYTECODE=1
ENV GLITCHHUNTER_HOME=/app
ENV GLITCHHUNTER_DATA=/app/data
ENV GLITCHHUNTER_LOGS=/app/logs
ENV GLITCHHUNTER_CACHE=/app/cache

# Port
EXPOSE 6262

# Health-Check
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
    CMD curl -f http://localhost:6262/api/v1/status || exit 1

# Start
CMD ["uvicorn", "ui.web.backend.app:app", "--host", "0.0.0.0", "--port", "6262"]
