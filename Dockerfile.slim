# GlitchHunter v3.0 Docker Image - Ultra-Slim
# Nur Web-UI, Dependencies zur Laufzeit

FROM python:3.11-slim

WORKDIR /app

# System-Dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    sshfs \
    fuse \
    openssh-client \
    && rm -rf /var/lib/apt/lists/*

# SSH known_hosts vorbereiten
RUN mkdir -p /root/.ssh && chmod 700 /root/.ssh

# Web-UI und src kopieren
COPY ui/web/ ui/web/
COPY src/ src/
COPY pyproject.toml ./
COPY config.yaml ./

# Dependencies zur Laufzeit installieren
RUN pip install --no-cache-dir --upgrade pip && \
    pip install --no-cache-dir -e .

# Verzeichnisse erstellen
RUN mkdir -p /app/logs /app/data /app/cache /app/reports

# Umgebungsvariablen
ENV PYTHONUNBUFFERED=1
ENV PYTHONDONTWRITEBYTECODE=1

# Port
EXPOSE 6262

# Health-Check
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
    CMD curl -f http://localhost:6262/api/v1/status || exit 1

# Start
CMD ["uvicorn", "ui.web.backend.app:app", "--host", "0.0.0.0", "--port", "6262"]
